{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents the player profile and their attributes.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "goals": { "type": "string", "description": "User's long-term goals and desires entered during onboarding." },
        "attributes": {
          "type": "object",
          "properties": {
            "strength": { "type": "integer" },
            "intelligence": { "type": "integer" },
            "creativity": { "type": "integer" },
            "stamina": { "type": "integer" }
          }
        },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "attributes", "xp", "level"]
    },
    "Quest": {
      "title": "Quest",
      "description": "A gamified task generated by the AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "attribute": { "type": "string", "enum": ["strength", "intelligence", "creativity", "stamina"] },
        "xpReward": { "type": "integer" },
        "type": { "type": "string", "enum": ["daily", "special"] },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "description", "difficulty", "attribute", "xpReward", "type", "status", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and progress."
    },
    "/quests/{questId}": {
      "schema": "Quest",
      "description": "Individual quests for users."
    }
  }
}
